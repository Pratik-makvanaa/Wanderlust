<style>
    .btn-search {
        background-color: rgb(255, 89, 0);
        color: #fff;
        border-radius: 25px;
        padding: 0.2rem 1rem 0.2rem 1rem;
    }
    .search-in{
        border-radius: 25px;
        padding: 0.2rem 2rem 0.2rem 2rem;
    }
    .btn-search:hover{
        background-color: rgb(255, 89, 0);
        color: #fff;
    }
    .btn-search i {
        display: inline;
        margin-right: 0.5rem;
    }
</style>


<nav class="navbar navbar-expand-md navbar-light bg-body-tertiary sticky-top border-bottom">
    <div class="container">
        <a class="navbar-brand " href="#"><i class="fa-solid fa-compass"></i></a>
        <!-- Toggle Button for Mobile -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup"
            aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <!-- Navbar Links -->
        <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
            <div class="navbar-nav ">
                <a class="nav-link" href="/listings">Home</a>
            </div>
            <div class="navbar-nav ms-auto">
                <form class="d-flex" role="search" >
                    <!-- method="GET" action="/search"> -->
                    <input class="form-control me-2 search-in" 
                    type="search" name="query" placeholder="Search Destination" 
                    aria-label="Search">
                    <button class="btn btn-search" type="submit">
                        <i class="fa-solid fa-magnifying-glass"></i>Search</button>
                </form>
            </div>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/listings/new">Add New</a>
                <% if(!currUser) { %>
                    <a class="nav-link" href="/signup"><b>Sign Up</b></a>
                    <a class="nav-link" href="/login"><b>Log in </b></a>
                <% } %>
                <% if(currUser) { %>
                        <a class="nav-link" href="/logout"><b>Log Out</b></a>
                <% } %>
            </div>
        </div>
    </div>
</nav>